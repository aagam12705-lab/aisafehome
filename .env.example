
# Copy this file to .env for local testing.
# Never commit your real .env file to GitHub.

# fake = sample demo hazards
# real = OpenAI vision analysis
AI_ANALYSIS_MODE=fake

# Add this only in your real local .env file or Streamlit secrets.
OPENAI_API_KEY=your_api_key_here

# Current OpenAI docs use gpt-5.5 in Responses API examples.
OPENAI_MODEL=gpt-5.5