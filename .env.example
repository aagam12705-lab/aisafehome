# AI SafeHome environment settings
# Copy this file to .env for local testing.
# Never commit your real .env file to GitHub.

# fake = sample demo hazards
# real = OpenAI vision analysis
AI_ANALYSIS_MODE=fake

# OpenAI key for real AI mode
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.5

# Database feature flag
# false = database saving is off
# true = database saving is on
DATABASE_ENABLED=false

# Supabase database settings
# Add real values only in .env or Streamlit secrets.
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server-side email feature
# false = do not send server-side emails
# true = allow server-side email sending
EMAIL_ENABLED=false

# Email provider
EMAIL_PROVIDER=brevo

# Brevo API settings
# Real values go only in .env or Streamlit secrets.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_sender_email_here
BREVO_SENDER_NAME=AI SafeHome